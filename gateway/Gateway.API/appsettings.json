{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },

  "IpRateLimiting": {
  "EnableEndpointRateLimiting": true,
  "StackBlockedRequests": false,
  "RealIpHeader": "X-Real-IP",
  "ClientIdHeader": "X-ClientId",
  "HttpStatusCode": 429,
  "GeneralRules": [
    {
      "Endpoint": "*",
      "Period": "1m",
      "Limit": 100
    },
    {
      "Endpoint": "post:/api/identity/login",
      "Period": "1m",
      "Limit": 10
    },
    {
      "Endpoint": "post:/api/identity/register",
      "Period": "1h",
      "Limit": 5
    },
    {
      "Endpoint": "post:/api/upload/*",
      "Period": "1m",
      "Limit": 30
    }
  ]
},
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "IdentityDb": "Server=localhost,1433;Database=IdentityDb;User Id=sa;Password=SaaS@MsSql2024!;TrustServerCertificate=True;"
  },
  "Seq": {
  "Endpoint": "http://localhost:5341",
  "MinimumLevel" : "Information"
},
  "JwtSettings": {
    "SecretKey": "YourSuperSecretKeyThatIsAtLeast32CharactersLong!",
    "Issuer": "ProjectSaaS.Identity",
    "Audience": "ProjectSaaS.API",
    "ExpiryMinutes": 60
  },
  "ReverseProxy": {
    "Routes": {
      "identity-swagger-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "public-access",
        "Match": {
          "Path": "/identity-swagger/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/swagger/{**catch-all}" }
        ]
      },
      "identity-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "public-access",
        "Match": {
          "Path": "/api/identity/{**catch-all}"
        }
      },
      "document-route": {
        "ClusterId": "document-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/documents/{**catch-all}"
        }
      },
      "upload-route": {
        "ClusterId": "document-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/upload/{**catch-all}"
        }
      },
      "workflow-route": {
        "ClusterId": "workflow-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/workflow/{**catch-all}"
        }
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-destination": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "document-cluster": {
        "Destinations": {
          "document-service": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "workflow-cluster": {
        "Destinations": {
          "workflow-service": {
            "Address": "http://localhost:5003"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification-service": {
            "Address": "http://localhost:5004"
          }
        }
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Yarp": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "Gateway.API"
    }
  }
}
